# ~/.bashrc

[ -z "$PS1" ] && return

HISTSIZE=5000
HISTFILESIZE=10000
HISTCONTROL=ignoreboth:erasedups
shopt -s histappend

export EDITOR=vim
export VISUAL=vim
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

export PROJECTS_HOME="/home/jschoi0223/projects"
export MONEY_SCOOP_HOME="/home/jschoi0223/projects/moneyscoop"

if [ -f "$HOME/dotfiles/bash/aliases" ]; then
    . "$HOME/dotfiles/bash/aliases"
fi

PS1='\u@\h:\w\$ '

HOST_FILE="$HOME/dotfiles/hosts/$(hostname).sh"
if [ -f "$HOST_FILE" ]; then
    . "$HOST_FILE"
fi

mss() {
    cd "$MONEY_SCOOP_HOME" || return 1
    git status -sb
}




mkcd() {
    mkdir -p "$1" && cd "$1"
}

croot() {
    local root
    root=$(git rev-parse --show-toplevel 2>/dev/null) || {
        echo "현재 Git 저장소 안이 아닙니다."
        return 1
    }
    cd "$root" || return 1
}

gpush() {
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    if [ -z "$branch" ]; then
        echo "현재 Git 브랜치를 찾을 수 없습니다."
        return 1
    fi
    git push origin "$branch"
}

gpull() {
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    if [ -z "$branch" ]; then
        echo "현재 Git 브랜치를 찾을 수 없습니다."
        return 1
    fi
    git pull origin "$branch"
}

gsync() {
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    if [ -z "$branch" ]; then
        echo "현재 Git 브랜치를 찾을 수 없습니다."
        return 1
    fi

    git status -sb || return 1
    git pull origin "$branch" || return 1
    git push origin "$branch"
}

dotsave() {
    cd "$HOME/dotfiles" || return 1
    git add .

    if git diff --cached --quiet; then
        echo "반영할 변경사항이 없습니다."
        return 0
    fi

    git commit -m "${1:-Update dotfiles}" && git push
}

dotload() {
    cd "$HOME/dotfiles" || return 1
    git pull && source "$HOME/.bashrc"
}

mssave() {
    cd "$MONEY_SCOOP_HOME" || return 1
    git add .

    if git diff --cached --quiet; then
        echo "반영할 변경사항이 없습니다."
        return 0
    fi

    git commit -m "${1:-Update moneyscoop}" && git push
}

msload() {
    cd "$MONEY_SCOOP_HOME" || return 1
    git pull
}

mscode() {
    cd "$MONEY_SCOOP_HOME" || return 1
    claude
}

memo() {
    mkdir -p "$HOME/notes"
    printf '%s %s\n' "- $(date '+%F %T')" "$*" >> "$HOME/notes/inbox.md"
    tail -n 3 "$HOME/notes/inbox.md"
}

msmemo() {
    printf '%s %s\n' "- $(date '+%F %T')" "$*" >> "$MONEY_SCOOP_HOME/NOTES.md"
    tail -n 3 "$MONEY_SCOOP_HOME/NOTES.md"
}

claudememo() {
    mkdir -p "$MONEY_SCOOP_HOME/.claude"
    printf '%s %s\n' "- $(date '+%F %T')" "$*" >> "$MONEY_SCOOP_HOME/.claude/CLAUDE.md"
    tail -n 5 "$MONEY_SCOOP_HOME/.claude/CLAUDE.md"
}

# color settings
export TERM=xterm-256color

if command -v dircolors >/dev/null 2>&1; then
    eval "$(dircolors -b)"
fi

alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias diff='diff --color=auto'

# colorful prompt
if [ -n "$PS1" ]; then
    PS1='\[\e[1;32m\]\u@\h\[\e[0m\]:\[\e[1;34m\]\w\[\e[0m\]\$ '
fi


# terminal color
export TERM=xterm-256color
export CLICOLOR=1
export LSCOLORS=ExFxCxDxBxegedabagacad

if command -v dircolors >/dev/null 2>&1; then
    eval "$(dircolors -b)"
fi

alias ls='ls --color=auto -F'
alias ll='ls --color=auto -alF'
alias la='ls --color=auto -A'
alias l='ls --color=auto -CF'
alias grep='grep --color=auto'
alias diff='diff --color=auto'

# git branch in prompt
parse_git_branch() {
    git branch --show-current 2>/dev/null
}

PS1='\[\e[1;32m\]\u@\h\[\e[0m\]:\[\e[1;34m\]\w\[\e[0m\]\[\e[1;33m\]$(b=$(parse_git_branch); [ -n "$b" ] && printf " [%s]" "$b")\[\e[0m\]\$ '
